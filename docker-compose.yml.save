
services:
  mysql:
    image: mysql:8.0
    container_name: kisanvani_mysql
    environment:
      MYSQL_ROOT_PASSWORD: rootpassword
      MYSQL_DATABASE: kisanvani_db
      MYSQL_USER: root
      MYSQL_PASSWORD: Root@12345
    ports:
      - "3307:3306"
    volumes:
      - mysql_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 20s
      retries: 10
    networks:
      - kisanvani_network

  redis:
    image: redis:7-alpine
    container_name: kisanvani_redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - kisanvani_network

  qdrant:
    image: qdrant/qdrant:latest
    container_name: kisanvani_qdrant
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - qdrant_data:/qdrant/storage
    environment:
      QDRANT__SERVICE__GRPC_PORT: 6334
    networks:
      - kisanvani_network

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: kisanvani_backend
    ports:
      - "8001:8001"
    environment:
      MYSQL_HOST: mysql
      MYSQL_PORT: 3306
      MYSQL_USER: root
      MYSQL_PASSWORD: Root@12345
      MYSQL_DATABASE: kisanvani_db
      REDIS_URL: redis://redis:6379
      QDRANT_URL: http://qdrant:6333
      CORS_ORIGINS: http://localhost:3000
      DEFAULT_STT_PROVIDER: mock
      DEFAULT_TTS_PROVIDER: mock
      DEFAULT_LLM_PROVIDER: openai
      DEFAULT_LLM_MODEL: gpt-4
    depends_on:
      mysql:
        condition: service_healthy
      redis:
        condition: service_healthy
      qdrant:
        condition: service_started
    volumes:
      - ./backend:/app
    networks:
      - kisanvani_network
    command: >
      sh -c "sleep 15 &&
      alembic upgrade head &&
      uvicorn server:app --host 0.0.0.0 --port 8001 --reload"

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: kisanvani_frontend
    ports:
      - "3000:3000"
    environment:
      REACT_APP_BACKEND_URL: http://localhost:8001
    depends_on:
      - backend
    volumes:
      - ./frontend:/app
      - /app/node_modules
    networks:
      - kisanvani_network

volumes:
  mysql_data:
  redis_data:
  qdrant_data:

networks:
  kisanvani_network:
    driver: bridge
