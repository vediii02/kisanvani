from typing import Dict, Type, Any
from abc import ABC, abstractmethod

class BaseSTTProvider(ABC):
    @abstractmethod
    async def transcribe(self, audio_data: bytes) -> str:
        pass

class BaseTTSProvider(ABC):
    @abstractmethod
    async def synthesize(self, text: str, language: str = 'hi') -> bytes:
        pass

class BaseLLMProvider(ABC):
    @abstractmethod
    async def generate(self, prompt: str, system_message: str = None) -> str:
        pass

class MockSTTProvider(BaseSTTProvider):
    async def transcribe(self, audio_data: bytes) -> str:
        return "[Mock STT] मेरे गेहूं की फसल में पीले पत्ते आ रहे हैं"

class MockTTSProvider(BaseTTSProvider):
    async def synthesize(self, text: str, language: str = 'hi') -> bytes:
        return b"[Mock TTS Audio Data]"

class ProviderRegistry:
    def __init__(self):
        self._stt_providers: Dict[str, Type[BaseSTTProvider]] = {}
        self._tts_providers: Dict[str, Type[BaseTTSProvider]] = {}
        self._llm_providers: Dict[str, Type[BaseLLMProvider]] = {}
        
        # Register mock providers
        self.register_stt('mock', MockSTTProvider)
        self.register_tts('mock', MockTTSProvider)
    
    def register_stt(self, name: str, provider_class: Type[BaseSTTProvider]):
        self._stt_providers[name] = provider_class
    
    def register_tts(self, name: str, provider_class: Type[BaseTTSProvider]):
        self._tts_providers[name] = provider_class
    
    def register_llm(self, name: str, provider_class: Type[BaseLLMProvider]):
        self._llm_providers[name] = provider_class
    
    def get_stt(self, name: str, **kwargs) -> BaseSTTProvider:
        if name not in self._stt_providers:
            raise ValueError(f"STT provider '{name}' not registered")
        return self._stt_providers[name](**kwargs)
    
    def get_tts(self, name: str, **kwargs) -> BaseTTSProvider:
        if name not in self._tts_providers:
            raise ValueError(f"TTS provider '{name}' not registered")
        return self._tts_providers[name](**kwargs)
    
    def get_llm(self, name: str, **kwargs) -> BaseLLMProvider:
        if name not in self._llm_providers:
            raise ValueError(f"LLM provider '{name}' not registered")
        return self._llm_providers[name](**kwargs)

provider_registry = ProviderRegistry()